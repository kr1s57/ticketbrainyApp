# ═══════════════════════════════════════════════════════
# TicketBrainy — Environment Configuration
# ═══════════════════════════════════════════════════════
# Copy this file to .env and fill in the required values.
# Required values are marked with # REQUIRED

# ─── Application ──────────────────────────────────────
APP_URL=http://localhost:3000
APP_PORT=3000

# ─── Database ─────────────────────────────────────────
DB_USER=ticketbrainy
DB_PASSWORD=                          # REQUIRED: strong password
DB_NAME=ticketbrainy
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@db:5432/${DB_NAME}

# ─── Redis ────────────────────────────────────────────
REDIS_PASSWORD=                       # REQUIRED: strong password for Redis
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# ─── Security ─────────────────────────────────────────
NEXTAUTH_SECRET=                      # REQUIRED: openssl rand -base64 32
NEXTAUTH_URL=${APP_URL}
ENCRYPTION_MASTER_KEY=                # REQUIRED: openssl rand -hex 32

# ─── Auth — Keycloak SSO (optional) ──────────────────
# Configure via UI at Settings → Authentication, or set here for initial setup.
#
# KEYCLOAK_URL must be the SAME public origin that serves the web UI
# (same reverse-proxy vhost). User-flow traffic (/realms/*, /resources/*,
# /js/*) is proxied through the web app's Next.js handlers to the
# Keycloak container over the Docker network. This avoids needing two
# WAF/reverse-proxy vhosts and keeps CORS / cookies same-origin with
# the web UI.
#
# The realm's `frontendUrl` attribute is pinned to KEYCLOAK_URL on every
# container start by keycloak/apply-config.sh. This ensures every email
# action link (enrollment, password reset, 2FA) uses this base URL even
# if an admin triggers the action from the LAN admin console.
#
# Example: KEYCLOAK_URL=https://support.example.com
KEYCLOAK_URL=
KEYCLOAK_REALM=ticketbrainy
KEYCLOAK_CLIENT_ID=ticketbrainy-web
KEYCLOAK_CLIENT_SECRET=
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=                    # Keycloak admin password (needed for user sync)
# The Keycloak admin console is only reachable via direct LAN access at
# http://<LAN_IP>:${KC_PORT}/admin/ — it is NOT proxied through the web
# app and must NOT be exposed publicly through the reverse proxy / WAF.
# The web app's middleware blocks /admin/* at the application layer and
# there is no Next.js route handler for it.
KC_PORT=8180                          # Keycloak HTTP port on host
KC_DB_SCHEMA=keycloak

# ─── AI Service ───────────────────────────────────────
AI_SERVICE_URL=http://ai-service:3001
AI_SERVICE_PORT=3001
INTERNAL_SERVICE_TOKEN=               # REQUIRED: openssl rand -hex 32 — authenticates web→AI service calls
# API key configured via UI at Settings → XpertTeamIA

# ─── Mail Service ─────────────────────────────────────
MAIL_SERVICE_URL=http://mail-service:3002
IMAP_POLL_INTERVAL=30

# ─── Storage ──────────────────────────────────────────
UPLOAD_STORAGE_PATH=/data/uploads
ATTACHMENT_STORAGE_PATH=/data/attachments
INSTANCE_ID_PATH=/data/.instance-id

# ─── License ──────────────────────────────────────────
VIGILANCE_KEY_URL=https://license.ticketbrainy.com

# ─── Seed ─────────────────────────────────────────────
SEED_ADMIN_PASSWORD=                  # REQUIRED (for seed only): initial admin password

# ─── Logging ──────────────────────────────────────────
LOG_LEVEL=info

# ─── Security (v1.10.0) ──────────────────────────────────────
# Keycloak Admin API client (read-only). The value is generated by
# keycloak/apply-config.sh on first boot and printed to the startup
# logs — copy it here. See docs/deployment-modes.md.
KC_ADMIN_READ_CLIENT_ID=ticketbrainy-admin-read
KC_ADMIN_READ_CLIENT_SECRET=

# Break-glass bypass for admin IP allowlist (set to "true" to disable
# the check when locked out of your own instance). Leave empty or
# unset in normal operation. See docs/deployment-modes.md §break-glass.
SECURITY_ALLOWLIST_BYPASS=
