###############################################################################
#  TicketBrainy — Environment Configuration
#
#  1. Copy this file:  cp .env.example .env
#  2. Run:  bash scripts/generate-secrets.sh
#     This fills all REQUIRED fields with secure random values.
#  3. Edit the remaining fields marked [EDIT] below.
#  4. Start:  docker compose up -d
###############################################################################

# ── Application ──────────────────────────────────────────────
# [EDIT] Public URL where users access TicketBrainy (with https if behind reverse proxy)
APP_URL=http://localhost:4000
# [EDIT] Port exposed on the host (default 4000)
APP_PORT=4000

# ── Database (PostgreSQL 16) ──────��──────────────────────────
DB_USER=ticketbrainy
DB_NAME=ticketbrainy
# [AUTO] Generated by generate-secrets.sh
DB_PASSWORD=

# ── Redis ────────────────────────────────────────────────────
# [AUTO] Generated by generate-secrets.sh
REDIS_PASSWORD=

# ── Security Secrets ─────────────────────────────────────────
# [AUTO] Generated by generate-secrets.sh — openssl rand -base64 32
NEXTAUTH_SECRET=
# [AUTO] Generated by generate-secrets.sh — openssl rand -hex 32
ENCRYPTION_MASTER_KEY=
# [AUTO] Generated by generate-secrets.sh — openssl rand -base64 32
INTERNAL_SERVICE_TOKEN=

# ── Initial Admin Account ────────────────────────────────────
# [AUTO] Generated by generate-secrets.sh
# Used only on first run to create the admin@ticketbrainy.local account.
# You can change it after first login in Settings > Team.
SEED_ADMIN_PASSWORD=

# ── Keycloak SSO (optional) ─────────────────────────────────
# Leave empty to use local authentication only.
# [EDIT] Set to your public Keycloak URL to enable SSO
KEYCLOAK_URL=
KEYCLOAK_REALM=ticketbrainy
KEYCLOAK_CLIENT_ID=ticketbrainy-web
# [AUTO] Generated by generate-secrets.sh
KEYCLOAK_CLIENT_SECRET=
KC_ADMIN_USER=admin
# [AUTO] Generated by generate-secrets.sh
KC_ADMIN_PASSWORD=
KC_PORT=8180
KC_DB_SCHEMA=keycloak

# ── Email Service ────────────────────────────────────────────
# IMAP polling interval in seconds (how often to check for new emails)
IMAP_POLL_INTERVAL=30

# ── OAuth (Microsoft 365 mailboxes) ─────────────────────────
# [EDIT] Only needed if you use Microsoft 365 OAuth for mailboxes.
# Set to your public callback URL: https://support.example.com/api/mailbox/oauth
OAUTH_REDIRECT_URL=

# ── LAN Access ───────────────────────────────────────────────
# [EDIT] Comma-separated list of LAN IPs/hostnames that show the local login form.
# The Keycloak SSO button only appears on these hosts.
LAN_HOSTS=localhost

# ── License Server ───���───────────────────────────────────────
# Do not change unless instructed by support.
VIGILANCE_KEY_URL=https://license.ticketbrainy.com

# ── Caddy Reverse Proxy (optional) ───────────────────────────
# Only used if you deploy with: docker compose --profile with-proxy up -d
# Leave empty if you use your own reverse proxy / WAF.
# [EDIT] Public domain for the main app (must point to this server)
APP_DOMAIN=
# [EDIT] Public domain for Keycloak SSO (required if using SSO with Caddy)
KEYCLOAK_DOMAIN=
# [EDIT] Email for Let's Encrypt notifications
LETSENCRYPT_EMAIL=

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
