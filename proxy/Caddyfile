# TicketBrainy Caddy Configuration
# HTTPS is automatic via Let's Encrypt (certificates auto-renewed)
# Domain names are read from environment variables

{
    email {$LETSENCRYPT_EMAIL}
    admin 0.0.0.0:2019 {
        origins caddy:2019 localhost:2019 127.0.0.1:2019
    }
    # v1.10.143: Cloudflare trusted proxies at server level.
    # When behind Cloudflare (Proxied / orange cloud), the TCP source
    # IP is a Cloudflare edge IP. This tells Caddy to read the real
    # client IP from X-Forwarded-For, so remote_ip matchers (Keycloak
    # admin allowlist) see the actual visitor IP.
    # Safe for non-Cloudflare installs: if no CF proxy is present,
    # no XFF header is injected and remote_ip falls back to TCP IP.
    # Source: https://www.cloudflare.com/ips-v4
    servers {
        trusted_proxies static 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22
    }
}

# TicketBrainy main app
{$APP_DOMAIN} {
    reverse_proxy web:3000 {
        # Required for AI streaming (Server-Sent Events)
        flush_interval -1
    }

    # Upload size limit
    request_body {
        max_size 10MB
    }

    # Security headers (complements app-level CSP)
    # v1.10.131 (hardening P1) — HSTS preload + COOP + Permissions-Policy + X-Frame-Options
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        X-Frame-Options "DENY"
        Cross-Origin-Opener-Policy "same-origin"
        Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
    }
}

# Keycloak SSO (required for public SSO login)
# v1.10.08: The Keycloak admin IP allowlist is now managed from
# Settings → Security in the TicketBrainy UI. When the operator saves
# a non-empty allowlist, the web container re-renders this file and
# hot-reloads Caddy via the admin API.
#
# v1.10.131 (hardening P1) — durcissements bootstrap :
#   - fix H-02 : blocage inconditionnel de /admin/*, /admin, /realms/master/*
#     → 404 hard, masque l'existence de la console admin Keycloak aux
#     scanners. Surchargé par le render dynamique en 403 allowlist si
#     l'opérateur configure un allowlist IP depuis l'UI.
#   - fix H-03 : stripping des headers CORS réfléchis par Keycloak en
#     amont + ré-émission conditionnelle pour l'Origin légitime
#     uniquement (defense-in-depth en plus du webOrigins realm-level).
{$KEYCLOAK_DOMAIN} {
    # v1.10.131 fix H-02 : bloc admin Keycloak (bootstrap statique).
    # Le render dynamique (via Settings → Security UI) peut remplacer
    # ce bloc par une allowlist IP en 403, mais par défaut au premier
    # boot avant toute config UI, on masque complètement l'existence
    # de l'admin console pour ne pas laisser une fenêtre d'exposition
    # publique entre `docker compose up` et le premier sync boot du
    # container web.
    @kc_admin_hidden {
        path /admin/* /admin /realms/master/*
    }
    respond @kc_admin_hidden 404

    # v1.10.131 fix H-03 : retirer les headers CORS réfléchis par
    # Keycloak avant d'appliquer notre propre whitelist.
    header -Access-Control-Allow-Origin
    header -Access-Control-Allow-Credentials
    header -Access-Control-Allow-Headers
    header -Access-Control-Allow-Methods
    header -Access-Control-Expose-Headers

    # Whitelist CORS : on ré-émet les headers UNIQUEMENT quand la
    # requête porte un Origin qui correspond exactement à l'origine
    # publique de ce vhost. Toute autre valeur (y compris null,
    # https://evil.example, http://localhost:*) se voit refuser le
    # bonus ACAO+ACAC → le navigateur bloque l'accès cross-origin.
    @legit_kc_origin header Origin https://{$KEYCLOAK_DOMAIN}
    header @legit_kc_origin Access-Control-Allow-Origin "https://{$KEYCLOAK_DOMAIN}"
    header @legit_kc_origin Access-Control-Allow-Credentials "true"
    header @legit_kc_origin Vary "Origin"

    reverse_proxy keycloak:8080

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        X-Frame-Options "DENY"
    }
}
