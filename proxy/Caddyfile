# TicketBrainy Caddy Configuration
# HTTPS is automatic via Let's Encrypt (certificates auto-renewed)
# Domain names are read from environment variables

{
    email {$LETSENCRYPT_EMAIL}
    # v1.10.08: expose the Caddy admin API on the docker internal
    # network so the TicketBrainy web container can hot-reload the
    # Caddyfile when the Keycloak admin IP allowlist is changed from
    # the UI. Bound to 0.0.0.0:2019 — this port is NOT mapped to the
    # host by docker-compose, so it stays on the internal network and
    # can only be reached from sibling containers.
    #
    # v1.10.09: explicit `origins` allowlist. When the admin API is
    # bound to a non-loopback address (0.0.0.0 here), Caddy's default
    # origin validation refuses every request with `client is not
    # allowed to access from origin ''`. We whitelist the docker
    # service hostname used by the web container's fetch, plus the
    # loopback variants for local debugging via SSH port-forward.
    admin 0.0.0.0:2019 {
        origins caddy:2019 localhost:2019 127.0.0.1:2019
    }
}

# TicketBrainy main app
{$APP_DOMAIN} {
    reverse_proxy web:3000 {
        # Required for AI streaming (Server-Sent Events)
        flush_interval -1
    }

    # Upload size limit
    request_body {
        max_size 10MB
    }

    # Security headers (complements app-level CSP)
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}

# Keycloak SSO (required for public SSO login)
# v1.10.08: The Keycloak admin IP allowlist is now managed from
# Settings → Security in the TicketBrainy UI. The initial Caddyfile
# has no remote_ip matcher; when the operator saves a non-empty
# allowlist in the UI, a server action re-renders this file and
# hot-reloads Caddy via the admin API. Empty list = no restriction.
{$KEYCLOAK_DOMAIN} {
    reverse_proxy keycloak:8080

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
    }
}
